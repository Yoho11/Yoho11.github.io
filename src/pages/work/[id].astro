---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths = (async () => {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);

const { title, summary, tech, links, cover } = project.data;
---

<Layout title={title} description={summary}>
	<a href="/work" class="text-sm text-indigo-600 hover:underline">← All projects</a>

	<article class="mt-6">
		<h1 class="text-3xl font-bold tracking-tight">{title}</h1>
		<p class="mt-2 text-neutral-500">{summary}</p>

		{tech.length > 0 && (
			<ul class="mt-4 flex flex-wrap gap-1.5">
				{tech.map((tag) => (
					<li class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-xs font-medium text-neutral-600">
						{tag}
					</li>
				))}
			</ul>
		)}

		{links && (
			<ul class="mt-4 flex flex-wrap gap-4 text-sm">
				{links.appStore && (
					<li>
						<a class="inline-flex items-center gap-1 rounded-lg border border-neutral-200 px-3 py-1.5 text-indigo-600 transition-colors hover:border-indigo-300 hover:bg-indigo-50" href={links.appStore}>
							App Store ↗
						</a>
					</li>
				)}
				{links.playStore && (
					<li>
						<a class="inline-flex items-center gap-1 rounded-lg border border-neutral-200 px-3 py-1.5 text-indigo-600 transition-colors hover:border-indigo-300 hover:bg-indigo-50" href={links.playStore}>
							Google Play ↗
						</a>
					</li>
				)}
				{links.github && (
					<li>
						<a class="inline-flex items-center gap-1 rounded-lg border border-neutral-200 px-3 py-1.5 text-indigo-600 transition-colors hover:border-indigo-300 hover:bg-indigo-50" href={links.github}>
							GitHub ↗
						</a>
					</li>
				)}
				{links.demo && (
					<li>
						<a class="inline-flex items-center gap-1 rounded-lg border border-neutral-200 px-3 py-1.5 text-indigo-600 transition-colors hover:border-indigo-300 hover:bg-indigo-50" href={links.demo}>
							Demo ↗
						</a>
					</li>
				)}
				{links.video && (
					<li>
						<a class="inline-flex items-center gap-1 rounded-lg border border-neutral-200 px-3 py-1.5 text-indigo-600 transition-colors hover:border-indigo-300 hover:bg-indigo-50" href={links.video}>
							Video ↗
						</a>
					</li>
				)}
			</ul>
		)}

		{cover && (
			<Image
				src={cover}
				alt={`${title} cover`}
				class="mt-8 w-full rounded-xl border border-neutral-200 object-cover shadow-sm"
			/>
		)}

		<div
			class="prose-project mt-8 text-neutral-700
				[&_h2]:mt-8 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-neutral-900
				[&_h3]:mt-6 [&_h3]:font-semibold [&_h3]:text-neutral-900
				[&_p]:mt-4
				[&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-5 [&_li]:mt-1
				[&_strong]:font-semibold [&_strong]:text-neutral-900
				[&_a]:text-indigo-600 [&_a]:underline
				[&_blockquote]:mt-4 [&_blockquote]:border-l-2 [&_blockquote]:border-neutral-200 [&_blockquote]:pl-3 [&_blockquote]:text-neutral-500
				[&_img]:mt-6 [&_img]:w-full [&_img]:rounded-xl [&_img]:border [&_img]:border-neutral-200 [&_img]:shadow-sm
				[&_img+img]:mt-4"
		>
			<Content />
		</div>
	</article>
</Layout>
