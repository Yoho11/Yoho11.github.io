---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../consts";

const projects = (await getCollection("projects")).sort(
	(a, b) =>
		(a.data.order ?? Infinity) - (b.data.order ?? Infinity) ||
		a.data.title.localeCompare(b.data.title),
);
---

<Layout title="Work" description="Projects, experience, and resume.">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<h1 class="text-3xl font-bold tracking-tight">Work</h1>
		<a
			href={SITE.resume}
			download
			class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-indigo-700"
		>
			<span aria-hidden="true">↓</span> Download résumé (PDF)
		</a>
	</div>
	<p class="mt-2 text-sm text-neutral-500">
		A snapshot of what I build — projects, experience, and the full résumé above.
	</p>

	<section class="mt-10">
		<h2 class="text-xl font-semibold">Projects</h2>
		{
			projects.length === 0 ? (
				<p class="mt-3 text-sm text-neutral-500">Projects coming soon.</p>
			) : (
				<ul class="mt-4 grid gap-4 sm:grid-cols-2">
					{projects.map((project) => (
						<li class="group relative flex flex-col rounded-xl border border-neutral-200 p-5 transition-colors hover:border-indigo-300 hover:bg-indigo-50/40">
							<a href={`/work/${project.id}`} class="absolute inset-0 rounded-xl" aria-label={project.data.title} />
							<h3 class="font-semibold text-indigo-700">{project.data.title}</h3>
							<p class="mt-1 text-sm text-neutral-600">{project.data.summary}</p>
							{project.data.tech.length > 0 && (
								<ul class="mt-3 flex flex-wrap gap-1.5">
									{project.data.tech.map((tag) => (
										<li class="rounded-full bg-neutral-100 px-2 py-0.5 text-xs text-neutral-600">
											{tag}
										</li>
									))}
								</ul>
							)}
							<div class="mt-4 flex items-center justify-between">
								{project.data.links ? (
									<ul class="relative z-10 flex flex-wrap gap-3 text-sm">
										{project.data.links.appStore && (
											<li>
												<a class="text-indigo-600 hover:underline" href={project.data.links.appStore}>
													App Store
												</a>
											</li>
										)}
										{project.data.links.playStore && (
											<li>
												<a class="text-indigo-600 hover:underline" href={project.data.links.playStore}>
													Google Play
												</a>
											</li>
										)}
										{project.data.links.github && (
											<li>
												<a class="text-indigo-600 hover:underline" href={project.data.links.github}>
													GitHub
												</a>
											</li>
										)}
										{project.data.links.demo && (
											<li>
												<a class="text-indigo-600 hover:underline" href={project.data.links.demo}>
													Demo
												</a>
											</li>
										)}
										{project.data.links.video && (
											<li>
												<a class="text-indigo-600 hover:underline" href={project.data.links.video}>
													Video
												</a>
											</li>
										)}
									</ul>
								) : <span />}
								<span class="text-xs font-medium text-indigo-500 group-hover:text-indigo-700 transition-colors">
									View project →
								</span>
							</div>
						</li>
					))}
				</ul>
			)
		}
	</section>

	<section class="mt-10">
		<h2 class="text-xl font-semibold">Experience</h2>

		<div class="mt-4">
			<div class="flex flex-wrap items-baseline justify-between gap-x-3">
				<h3 class="font-semibold">Software Engineer · InfinitePlay S.r.l.</h3>
				<span class="text-sm text-neutral-500">May 2020 – Present</span>
			</div>
			<p class="text-sm text-neutral-500">Padova, Italy</p>
			<ul class="mt-3 space-y-2 text-sm text-neutral-600 list-disc pl-5">
				<li>
					Led iOS development (Swift/UIKit) on IpDoor and ported Android features to
					iOS, reducing crash reports by 40%+ and improving the App Store rating.
				</li>
				<li>
					Implemented VoIP push via PushKit/CallKit and fixed unreliable incoming-call
					delivery by resolving an APNs content-available / mutable-content throttling
					issue.
				</li>
				<li>
					Designed GRDB/SQLite persistence with a transactional cross-table sync
					repository, preventing data loss during delete-and-reinsert cycles.
				</li>
				<li>
					Added Core Bluetooth pairing and device provisioning on iOS.
				</li>
				<li>
					Built core Android features — UI, app logic, and local persistence (Room,
					Retrofit/OkHttp, Firebase FCM/Crashlytics) — for consumer phones and
					custom Rockchip-based Android 11 embedded touchscreens.
				</li>
				<li>
					Resolved ANRs and eliminated a foreground-service kill/restart loop on
					Android, improving device uptime; added Bluetooth and NFC support that
					opened up new markets.
				</li>
				<li>
					Built and debugged SIP/VoIP calling (Linphone) across iOS, Android, and
					Electron through a FreeSWITCH back-to-back user agent, resolving
					transfer/hold/media-negotiation defects with pcap/Wireshark analysis.
				</li>
				<li>
					Customized AOSP (Android 11) for embedded devices — SELinux policy, Bluetooth
					HAL debugging, and OTA/log-filtering improvements that increased reliability.
				</li>
				<li>
					Delivered React Native and Electron features for a desktop-focused
					multi-platform app, plus a Next.js/React (TypeScript) frontend with
					localization and cross-browser support.
				</li>
				<li>
					Maintained a shared cross-platform SDK and ran code reviews/pair-programming;
					ran self-hosted Git infrastructure and built an S3-based diagnostic
					log-collection pipeline spanning Android, iOS, and Electron.
				</li>
			</ul>
		</div>

		<div class="mt-6">
			<div class="flex flex-wrap items-baseline justify-between gap-x-3">
				<h3 class="font-semibold">Machine Learning Intern · Synclab S.r.l.</h3>
				<span class="text-sm text-neutral-500">Sep 2019 – Oct 2019</span>
			</div>
			<p class="text-sm text-neutral-500">Padova, Italy</p>
			<ul class="mt-3 space-y-2 text-sm text-neutral-600 list-disc pl-5">
				<li>
					Applied Python machine-learning techniques to medical documentation,
					including data preprocessing, model training, and evaluation.
				</li>
			</ul>
		</div>
	</section>

	<section class="mt-10">
		<h2 class="text-xl font-semibold">Education &amp; Languages</h2>
		<p class="mt-3 text-sm text-neutral-600">
			BSc in Computer Engineering — University of Padova, Italy (2020)
		</p>
		<p class="mt-1 text-sm text-neutral-600">
			Italian (native) · Romanian (native) · English (B2) · Japanese (JLPT N4)
		</p>
	</section>
</Layout>
