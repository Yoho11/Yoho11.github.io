---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../consts";
---

<Layout title="Contact" description="Get in touch.">
	<h1 class="text-3xl font-bold tracking-tight">Contact</h1>
	<p class="mt-2 text-neutral-600">
		The best way to reach me is email. I'm also on LinkedIn and GitHub.
	</p>

	<ul class="mt-8 space-y-3">
		<li>
			<span class="text-neutral-500">Email </span>
			<a class="text-indigo-600 hover:underline" href={`mailto:${SITE.email}`}>
				{SITE.email}
			</a>
		</li>
		<li>
			<span class="text-neutral-500">LinkedIn </span>
			<a
				class="text-indigo-600 hover:underline"
				href={SITE.linkedin}
				target="_blank"
				rel="noopener noreferrer"
			>
				{SITE.linkedin.replace("https://", "")}
			</a>
		</li>
		{
			SITE.github && (
				<li>
					<span class="text-neutral-500">GitHub </span>
					<a
						class="text-indigo-600 hover:underline"
						href={SITE.github}
						target="_blank"
						rel="noopener noreferrer"
					>
						{SITE.github.replace("https://", "")}
					</a>
				</li>
			)
		}
	</ul>
</Layout>
