---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("posts")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

const dateFormat = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
});
---

<Layout title="Personal" description="Notes on cooking, travel, and sport.">
	<h1 class="text-3xl font-bold tracking-tight">Personal</h1>
	<p class="mt-2 text-neutral-600">
		A feed of things I make and do outside of work.
	</p>

	{
		posts.length === 0 ? (
			<p class="mt-8 text-sm text-neutral-500">Posts coming soon.</p>
		) : (
			<>
				<div class="mt-8 flex flex-wrap gap-2" role="group" aria-label="Filter posts by tag">
					<button
						type="button"
						data-filter="*"
						aria-pressed="true"
						class="rounded-full px-3 py-1 text-sm transition-colors bg-indigo-600 text-white"
					>
						All
					</button>
					{tags.map((tag) => (
						<button
							type="button"
							data-filter={tag}
							aria-pressed="false"
							class="rounded-full px-3 py-1 text-sm transition-colors bg-neutral-100 text-neutral-700 hover:bg-neutral-200"
						>
							{tag}
						</button>
					))}
				</div>

				<ul class="mt-8 space-y-6">
					{posts.map((post) => (
						<li data-tags={post.data.tags.join(",")} class="border-b border-neutral-200 pb-6">
							<article>
								<h2 class="text-lg font-semibold">
									<a href={`/personal/${post.id}`} class="transition-colors hover:text-indigo-700">
										{post.data.title}
									</a>
								</h2>
								<time datetime={post.data.date.toISOString()} class="text-xs text-neutral-500">
									{dateFormat.format(post.data.date)}
								</time>
								{post.data.excerpt && (
									<p class="mt-2 text-sm text-neutral-600">{post.data.excerpt}</p>
								)}
								<ul class="mt-3 flex flex-wrap gap-1.5">
									{post.data.tags.map((tag) => (
										<li class="rounded-full bg-neutral-100 px-2 py-0.5 text-xs text-neutral-600">
											{tag}
										</li>
									))}
								</ul>
								<a
									href={`/personal/${post.id}`}
									class="mt-3 inline-block text-sm text-indigo-600 hover:underline"
								>
									Read post →
								</a>
							</article>
						</li>
					))}
				</ul>

				<p data-empty hidden class="mt-8 text-sm text-neutral-500">
					No posts with that tag yet.
				</p>
			</>
		)
	}
</Layout>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
	const posts = document.querySelectorAll<HTMLElement>("[data-tags]");
	const empty = document.querySelector<HTMLElement>("[data-empty]");

	function apply(filter: string) {
		let visible = 0;
		posts.forEach((post) => {
			const tags = (post.dataset.tags ?? "").split(",");
			const match = filter === "*" || tags.includes(filter);
			post.hidden = !match;
			if (match) visible++;
		});

		buttons.forEach((button) => {
			const active = button.dataset.filter === filter;
			button.setAttribute("aria-pressed", String(active));
			button.classList.toggle("bg-indigo-600", active);
			button.classList.toggle("text-white", active);
			button.classList.toggle("bg-neutral-100", !active);
			button.classList.toggle("text-neutral-700", !active);
			button.classList.toggle("hover:bg-neutral-200", !active);
		});

		if (empty) empty.hidden = visible > 0;
	}

	buttons.forEach((button) =>
		button.addEventListener("click", () => apply(button.dataset.filter ?? "*")),
	);
</script>
