---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../consts";
---

<Layout>
	<section class="flex flex-col sm:flex-row sm:items-center gap-6">
		<div
			class="shrink-0 w-28 h-28 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center text-neutral-400 text-xs"
		>
			Portrait
		</div>
		<div>
			<h1 class="text-3xl font-bold tracking-tight">Hi, I'm {SITE.name}.</h1>
			<p class="mt-2 text-neutral-600">
				I'm an iOS software engineer with 6 years building Swift/UIKit apps for
				consumer and custom embedded devices, backed by strong cross-platform
				Android experience. This site is a quick tour of my work and the things I
				make for fun.
			</p>
			<p class="mt-2 text-sm text-neutral-500">{SITE.location} · Open to relocation</p>
		</div>
	</section>

	<section class="mt-10 grid gap-4 sm:grid-cols-2">
		<a
			href="/work"
			class="group rounded-xl border border-indigo-100 bg-indigo-50/40 p-5 transition-colors hover:border-indigo-300 hover:bg-indigo-50"
		>
			<h2 class="font-semibold text-indigo-700">Work →</h2>
			<p class="mt-1 text-sm text-neutral-600">
				Projects, experience, and my résumé.
			</p>
		</a>
		<a
			href="/personal"
			class="group rounded-xl border border-emerald-100 bg-emerald-50/40 p-5 transition-colors hover:border-emerald-300 hover:bg-emerald-50"
		>
			<h2 class="font-semibold text-emerald-700">Personal →</h2>
			<p class="mt-1 text-sm text-neutral-600">
				Notes on cooking, travel, and sport.
			</p>
		</a>
	</section>
</Layout>
